{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poker-dealer.local/schemas/card-observation-1.0.json",
  "title": "Stable card-slot observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "observation_id", "slot_id", "observed_at_ns", "status",
    "card", "confidence", "model_version", "calibration_version",
    "stable_frames", "quality_flags"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "observation_id": {"type": "string", "minLength": 1},
    "slot_id": {"$ref": "#/$defs/vision_slot"},
    "observed_at_ns": {"type": "integer", "minimum": 0},
    "status": {
      "enum": [
        "confirmed", "unknown", "empty", "face_down",
        "face_up_unconfirmed", "occluded"
      ]
    },
    "card": {"oneOf": [{"$ref": "#/$defs/card"}, {"type": "null"}]},
    "confidence": {"oneOf": [{"type": "number", "minimum": 0, "maximum": 1}, {"type": "null"}]},
    "model_version": {"type": "string", "minLength": 1},
    "calibration_version": {"type": "string", "minLength": 1},
    "stable_frames": {"type": "integer", "minimum": 1},
    "quality_flags": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "confirmed"}}},
      "then": {
        "properties": {
          "card": {"$ref": "#/$defs/card"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      },
      "else": {"properties": {"card": {"type": "null"}}}
    }
  ],
  "$defs": {
    "vision_slot": {
      "enum": [
        "board_flop_1", "board_flop_2", "board_flop_3", "board_turn",
        "board_river", "seat_a_hole_1", "seat_a_hole_2",
        "seat_b_hole_1", "seat_b_hole_2", "seat_c_hole_1",
        "seat_c_hole_2", "seat_d_hole_1", "seat_d_hole_2"
      ]
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "suit"],
      "properties": {
        "rank": {"enum": ["2", "3", "4", "5", "6", "7", "8", "9", "T", "J", "Q", "K", "A"]},
        "suit": {"enum": ["clubs", "diamonds", "hearts", "spades"]}
      }
    }
  }
}
