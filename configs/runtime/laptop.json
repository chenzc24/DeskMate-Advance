{
  "schema_version": "1.0",
  "profile_id": "laptop",
  "camera": {
    "kind": "local",
    "source_id": "laptop_camera",
    "device_index": 0,
    "backend": "dshow",
    "width": 1280,
    "height": 720,
    "fps": 30.0,
    "open_timeout_ms": 5000,
    "read_timeout_ms": 2000
  },
  "dealer": {
    "adapter": "simulated",
    "device_id": "simulated-laptop-dealer",
    "protocol_version": "2.0",
    "physical_motion": false,
    "enabled": true
  },
  "perception": {
    "identity_config": "configs/perception/face_identity_session.json",
    "gesture_config": "configs/perception/actions_laptop_pilot.json",
    "speech_config": "configs/perception/actions_speech_pilot.json",
    "speaker_config": "configs/perception/speaker_verification_session.json",
    "attribution_config": "configs/perception/actor_binding_session.json",
    "card_config": "configs/perception/cards_lgd_pilot.json",
    "calibration_id": "laptop-development-unfrozen-v1",
    "target_geometry_validated": false
  },
  "controls": ["laptop_keyboard"],
  "speech": {"enabled": true, "device": null},
  "logging": {"root": "runs/runtime/laptop"}
}
