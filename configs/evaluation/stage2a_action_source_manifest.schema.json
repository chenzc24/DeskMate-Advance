{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/poker-dealer/stage2a-action-source-manifest.schema.json",
  "title": "Stage 2A Action Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_id",
    "grammar_version",
    "status",
    "records"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "dataset_id": {"type": "string", "minLength": 2, "maxLength": 80},
    "grammar_version": {"type": "string", "minLength": 2, "maxLength": 80},
    "status": {"enum": ["source", "resolved"]},
    "split_seed": {"type": "string", "minLength": 1},
    "source_records_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "participant_code",
          "session_id",
          "seat",
          "capture_path",
          "sha256",
          "bytes",
          "camera_id",
          "lighting",
          "label",
          "duration_ms",
          "contains_identity_media",
          "git_tracked"
        ],
        "properties": {
          "source_id": {"type": "string", "minLength": 2, "maxLength": 120},
          "participant_code": {"type": "string", "minLength": 2, "maxLength": 48},
          "session_id": {"type": "string", "minLength": 2, "maxLength": 80},
          "seat": {"enum": ["seat_a", "seat_b", "seat_c", "seat_d"]},
          "capture_path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 1},
          "camera_id": {"type": "string", "minLength": 1},
          "lighting": {"type": "string", "minLength": 1},
          "label": {
            "enum": [
              "fold",
              "check",
              "call",
              "bet",
              "raise",
              "no_action",
              "cancelled",
              "ambiguous",
              "occluded"
            ]
          },
          "duration_ms": {"type": "integer", "minimum": 1},
          "contains_identity_media": {"const": true},
          "git_tracked": {"const": false},
          "split": {"enum": ["train", "validation", "test"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
